# ─── Database ────────────────────────────────────────────────
# Neon PostgreSQL connection string
# Get yours at https://neon.tech (free tier)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Payload CMS ──────────────────────────────────────────────
# Generate a strong random secret: openssl rand -hex 32
PAYLOAD_SECRET=your-32-char-random-secret-here

# ─── App URL ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Media Storage (Cloudflare R2 / S3-compatible) ────────────
# Leave blank to use local disk storage in development
S3_BUCKET=your-bucket-name
S3_REGION=auto
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key

# ─── Email (Resend) ───────────────────────────────────────────
# Get a free API key at https://resend.com (3,000 emails/month free)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Where submission alerts are sent (your editorial inbox)
EDITORIAL_EMAIL=editorial@cestfort.com
# The "From" address — must be a verified domain in Resend
EMAIL_FROM=C'est Fort <noreply@cestfort.com>

# ─── Logging ──────────────────────────────────────────────────
# debug | info | warn | error  (defaults to debug in dev, info in prod)
LOG_LEVEL=info
